# Database Configuration
# Copy this file to .env and update with your database credentials

# PostgreSQL (recommended for production)
DATABASE_URL="postgresql://username:password@localhost:5432/axlerator?schema=public"

# SQLite (for local development - simpler setup)
# DATABASE_URL="file:./dev.db"
# Supabase — copy Project URL and anon/public key from Supabase Dashboard → Settings → API.
# Never commit real keys to git; put them only in .env or your host’s env vars.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_optional
NODE_ENV=development
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000
ALLOWED_ORIGINS=http://localhost:3000

# # SMS/OTP Service (Twilio)
# TWILIO_ACCOUNT_SID=your_twilio_account_sid
# TWILIO_AUTH_TOKEN=your_twilio_auth_token
# TWILIO_PHONE_NUMBER=+1234567890

# OTP Settings
OTP_EXPIRY_MINUTES=10
OTP_LENGTH=6
OTP_MAX_ATTEMPTS=5

