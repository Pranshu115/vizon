# Database Configuration
# Copy this file to .env.local and fill in values from Supabase → Settings → API

# PostgreSQL (recommended for production)
DATABASE_URL="postgresql://username:password@localhost:5432/axlerator?schema=public"

# SQLite (for local development - simpler setup)
# DATABASE_URL="file:./dev.db"

# Supabase (same project ref for URL + anon key — Dashboard → Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_public_key_here
# Optional: server-only scripts / admin (never expose to the browser)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

NODE_ENV=development
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_WINDOW_MS=60000
ALLOWED_ORIGINS=http://localhost:3000

# # SMS/OTP Service (Twilio)
# TWILIO_ACCOUNT_SID=your_twilio_account_sid
# TWILIO_AUTH_TOKEN=your_twilio_auth_token
# TWILIO_PHONE_NUMBER=+1234567890

# OTP Settings
OTP_EXPIRY_MINUTES=10
OTP_LENGTH=6
OTP_MAX_ATTEMPTS=5
